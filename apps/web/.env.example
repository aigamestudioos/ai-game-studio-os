# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commitar .env.local — já protegido pelo .gitignore da raiz do monorepo.

# --- Supabase ---
# URL do projeto Supabase (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Chave publicável (Settings → API → Publishable key). Exposta ao browser
# de propósito — sujeita a RLS, nunca dá acesso administrativo.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Chave secreta (Settings → API → Secret key). Bypassa RLS — NUNCA expor
# ao browser, usar apenas em código server-only (packages/database/admin-client.ts).
SUPABASE_SECRET_KEY=

# --- Deploy ---
# URL canônica de produção do produto (usada para links absolutos, metadata, etc.)
NEXT_PUBLIC_SITE_URL=

# URL do deployment atual na Vercel (preenchida automaticamente em produção
# pela própria Vercel via VERCEL_URL; aqui documentada para uso local/preview)
NEXT_PUBLIC_VERCEL_URL=
